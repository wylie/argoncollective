---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteTitle = "Argon Collective LLC";
const siteDescription =
  "Independent software studio creating thoughtful tools for readers, communities, and the organizations that support them.";

const projects = [
  {
    name: "Dogeared",
    href: "https://dogeared.app",
    linkLabel: "Visit Dogeared",
    status: null,
    description:
      "A community-minded book tracking and discovery app designed to help readers organize their bookshelves, discover new favorites, and connect through a shared love of reading.",
  },
  {
    name: "Cairn",
    href: null,
    linkLabel: "Contact Argon Collective about Cairn",
    status: "Coming Soon",
    description:
      "Modern operations software designed for climbing gyms, recreation centers, and other community-focused organizations that need reliable, easy-to-use tools.",
    detail:
      "Cairn is not publicly available yet. Get in touch for more information.",
  },
];
---

<BaseLayout title={siteTitle} description={siteDescription}>
  <main id="main" class="page">
    <section class="section hero" aria-labelledby="hero-title">
      <div class="container hero__inner">
        <p class="eyebrow">Independent software studio</p>
        <h1 id="hero-title">Argon Collective LLC</h1>
        <p class="tagline measure measure--tagline">
          Thoughtful software for readers, communities, and the people who
          support them.
        </p>
        <p class="lede measure">
          Argon Collective builds practical software designed to serve real
          people and organizations, with a focus on clarity, reliability, and
          day-to-day usefulness.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="about-title">
      <div class="container stack">
        <div class="section-heading">
          <p class="eyebrow">About</p>
          <h2 id="about-title">Small by design, built with care.</h2>
        </div>
        <p class="body-copy measure">
          Argon Collective LLC creates software with people in mind. From
          helping readers discover their next favorite book to supporting the
          organizations that bring communities together, we believe technology
          works best when it is practical, approachable, and built with care.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="projects-title">
      <div class="container stack">
        <div class="section-heading">
          <p class="eyebrow">Projects</p>
          <h2 id="projects-title">Focused tools for real communities.</h2>
        </div>
        <div class="project-grid">
          {
            projects.map((project) => (
              <article
                class:list={[
                  "card",
                  { "card--interactive": Boolean(project.href) },
                ]}
              >
                <div class="card__header">
                  <h3>
                    {project.href ? (
                      <a
                        class="card__title-link"
                        href={project.href}
                        target="_blank"
                        rel="noreferrer"
                      >
                        {project.name}
                      </a>
                    ) : (
                      project.name
                    )}
                  </h3>
                  {project.status && (
                    <p class="card__status">{project.status}</p>
                  )}
                </div>
                <p>{project.description}</p>
                {project.href ? (
                  <a
                    class="card__link"
                    href={project.href}
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`${project.linkLabel} (opens in a new tab)`}
                  >
                    {project.linkLabel}
                  </a>
                ) : (
                  <p class="card__detail">
                    {project.detail}{" "}
                    <a
                      class="card__inline-link"
                      href="mailto:hello@argoncollective.com"
                    >
                      Contact Argon Collective
                    </a>
                    .
                  </p>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="contact-title">
      <div class="container contact">
        <div class="section-heading">
          <p class="eyebrow">Contact</p>
          <h2 id="contact-title">Interested in our work or have a question?</h2>
        </div>
        <p class="body-copy measure">We&apos;d love to hear from you.</p>
        <a class="contact-link" href="mailto:hello@argoncollective.com">
          Email hello@argoncollective.com
        </a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>Argon Collective LLC</p>
      <p>{new Date().getFullYear()}</p>
      <p>Built with Astro.</p>
    </div>
  </footer>
</BaseLayout>

<style>
  .page {
    padding: 0 var(--page-gutter) 0;
  }

  .section {
    padding-top: 1.5rem;
  }

  .container {
    width: min(100%, var(--page-max-width));
    margin: 0 auto;
  }

  .measure {
    max-width: 68ch;
  }

  .stack {
    display: grid;
    gap: 1.25rem;
  }

  .hero {
    padding-top: 1.25rem;
  }

  .hero__inner,
  .contact,
  .card {
    border: 1px solid var(--border);
    background: var(--surface);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow);
  }

  .hero__inner {
    padding: 2rem;
    border-radius: calc(var(--radius) + 4px);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--accent);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1,
  h2 {
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  h1 {
    max-width: none;
    font-size: clamp(2.4rem, 6vw, 4.85rem);
    text-wrap: balance;
  }

  h2 {
    max-width: none;
    font-size: clamp(1.85rem, 4vw, 2.75rem);
    text-wrap: balance;
  }

  h3 {
    font-size: 1.3rem;
    line-height: 1.2;
  }

  .tagline {
    margin-top: 1rem;
    font-size: clamp(1.15rem, 3vw, 1.5rem);
    color: var(--text);
  }

  .measure--tagline {
    max-width: 34rem;
  }

  .lede,
  .body-copy {
    color: var(--muted);
    font-size: 1.05rem;
  }

  .lede {
    margin-top: 1.25rem;
  }

  .section-heading {
    display: grid;
    gap: 0.25rem;
  }

  .project-grid {
    display: grid;
    gap: 1rem;
  }

  .card {
    display: grid;
    gap: 1rem;
    padding: 1.4rem;
    border-radius: var(--radius-sm);
    transition:
      border-color 150ms ease,
      background-color 150ms ease,
      transform 150ms ease;
  }

  .card--interactive:hover {
    border-color: rgba(35, 87, 137, 0.24);
    background: rgba(255, 255, 255, 0.9);
  }

  .card:has(a:focus-visible) {
    border-color: rgba(31, 79, 123, 0.5);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 0 0 4px rgba(31, 79, 123, 0.12);
  }

  .card__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .card__title-link,
  .card__link,
  .card__inline-link {
    color: var(--accent);
    text-decoration-color: rgba(35, 87, 137, 0.3);
    text-underline-offset: 0.18em;
  }

  .card__title-link {
    text-decoration: none;
  }

  .card__title-link:hover,
  .card__link:hover,
  .card__inline-link:hover {
    text-decoration-color: currentColor;
  }

  .card__status {
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .card p,
  .card__detail {
    max-width: none;
    color: var(--muted);
    font-size: 1.05rem;
  }

  .card__link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 2.9rem;
    font-weight: 600;
    text-decoration-thickness: 0.08em;
  }

  .contact {
    display: grid;
    gap: 1rem;
    padding: 1.75rem;
    border-radius: var(--radius);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.75rem;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    text-decoration: none;
  }

  .contact-link:hover {
    background: #1c466c;
  }

  .footer {
    padding: 2rem var(--page-gutter) 2.5rem;
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  @media (min-width: 48rem) {
    .section {
      padding-top: 2rem;
    }

    .hero {
      padding-top: 2rem;
    }

    .hero__inner {
      padding: 3.5rem;
    }

    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }

    .footer__inner {
      justify-content: space-between;
    }
  }
</style>
